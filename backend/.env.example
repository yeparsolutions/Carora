# ============================================================
# STOCKYA - Variables de Entorno (Ejemplo)
# Archivo: backend/.env.example
# Instrucciones: Copia este archivo a .env y rellena tus valores
# ⚠️ NUNCA subas el .env real a GitHub
# ============================================================

# Base de Datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:tu-contraseña@localhost:5433/carora

# Autenticación JWT
# SECRET_KEY: Clave ultra-secreta para firmar tokens. Cambia en producción.
SECRET_KEY=tu-clave-secreta-super-fuerte-cambiar-en-produccion-123456789

# Algoritmo de encriptación JWT
ALGORITHM=HS256

# Expiración de token en minutos (1440 = 24 horas)
TOKEN_EXPIRY=1440

# Entorno (development, staging, production)
ENVIRONMENT=development
